{
  "manifest_version": 3,
  "name": "poke-browser",
  "version": "0.0.1",
  "description": "Browser automation bridge for MCP agents via WebSocket.",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "debugger",
    "storage"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "poke-browser",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
