# Optional: pin the WebSocket handshake secret (must match extension popup "Auth token" / storage wsAuthToken).
# If unset or empty, WebSocket auth is disabled (dev / zero-config on localhost).
POKE_BROWSER_TOKEN=

# WebSocket listen port for the extension (default 9009). Must match the extension popup "WS port".
POKE_BROWSER_WS_PORT=9009

# MCP HTTP mode listen port when using --http / --tunnel (default 8755).
POKE_BROWSER_MCP_PORT=8755
