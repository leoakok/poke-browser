{
  "name": "@leokok/poke-browser",
  "version": "0.1.1",
  "description": "MCP server + WebSocket bridge for the poke-browser Chrome extension",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "poke-browser": "./cli.mjs"
  },
  "files": [
    "dist",
    "cli.mjs",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:tunnel": "node cli.mjs",
    "dev": "npx tsx src/index.ts",
    "prepublishOnly": "npm run build",
    "serve": "node ./dist/index.js",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js",
    "inspector:dev": "npx @modelcontextprotocol/inspector node cli.mjs",
    "test": "vitest run tests/",
    "test:watch": "vitest tests/"
  },
  "keywords": [
    "poke",
    "mcp",
    "browser",
    "chrome",
    "automation"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ws": "^8.18.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
