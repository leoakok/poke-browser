{
  "manifest_version": 3,
  "name": "poke-browser",
  "version": "0.4.5",
  "description": "Browser automation bridge for MCP agents via WebSocket.",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "debugger",
    "storage",
    "cookies",
    "alarms",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "poke-browser",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
